{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cors-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "ALLOWED_SITE": "",
    "ALLOWED_TARGET": "web.archive.org",
    "BLACKLIST_SITE": "",
    "REMOVE_HEADERS": "",
    "REQUIRE_HEADER": ""
  }
}
